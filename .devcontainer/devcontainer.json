{
  "name": "Gulimall Fullstack (Java 8 + Node 10)",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "8",
      "jdkDistro": "ms",
      "installMaven": "true"
    },
    // 👇 新增：在这里像搭积木一样注入 Node 10 环境
    "ghcr.io/devcontainers/features/node:1": {
      "version": "10.16.3"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ritwickdey.LiveServer",
        "octref.vetur",
        "dbaeumer.vscode-eslint",
        "ecmel.vscode-html-css",
        "xabikos.JavaScriptSnippets",
        "formulahendry.auto-close-tag",
        "formulahendry.auto-rename-tag",
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack",
        "GitHub.copilot-chat"
      ],
      "settings": {
        // 1. 让 Java 和 Spring Boot 插件去 /opt/jdk-17 找高版本 JDK 运行自己
        "java.jdt.ls.java.home": "/opt/jdk-17",
        "spring-boot.ls.java.home": "/opt/jdk-17",
        // 2. 告诉 VS Code 你的项目依然使用容器默认的 Java 8
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-1.8",
            "path": "/usr/local/sdkman/candidates/java/current",
            "default": true
          }
        ],
        "editor.formatOnSave": true,
        "editor.tabSize": 2
      }
    }
  },
  // 👇 修改：在脚本最前面追加了自动更新并安装字体库的命令
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y fontconfig fonts-dejavu && sudo mkdir -p /opt/jdk-17 && wget -qO- https://aka.ms/download-jdk/microsoft-jdk-17-linux-x64.tar.gz | sudo tar xz --strip-components=1 -C /opt/jdk-17 && npm config set registry https://registry.npmmirror.com && npm config set sass_binary_site https://npmmirror.com/mirrors/node-sass/ && java -version && mvn -version && node -v",
  "remoteUser": "vscode"
}