{
  "name": "Java 8 Dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "8",
      "jdkDistro": "ms",
      "installMaven": "true"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ritwickdey.LiveServer",
        "octref.vetur",
        "dbaeumer.vscode-eslint",
        "ecmel.vscode-html-css",
        "xabikos.JavaScriptSnippets",
        "formulahendry.auto-close-tag",
        "formulahendry.auto-rename-tag",
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack"
      ],
      "settings": {
        // 1. 让 Java 和 Spring Boot 插件去 /opt/jdk-17 找高版本 JDK 运行自己
        "java.jdt.ls.java.home": "/opt/jdk-17",
        "spring-boot.ls.java.home": "/opt/jdk-17",
        
        // 2. 告诉 VS Code 你的项目依然使用容器默认的 Java 8
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-1.8",
            "path": "/usr/local/sdkman/candidates/java/current",
            "default": true
          }
        ],
        "editor.formatOnSave": true,
        "editor.tabSize": 2
      }
    }
  },

  // 3. 在容器创建时，额外下载一个免安装版的 JDK 17 解压到 /opt/jdk-17 供插件专用，绝对不污染系统环境变量
  "postCreateCommand": "sudo mkdir -p /opt/jdk-17 && wget -qO- https://aka.ms/download-jdk/microsoft-jdk-17-linux-x64.tar.gz | sudo tar xz --strip-components=1 -C /opt/jdk-17 && java -version && mvn -version",
  
  "remoteUser": "vscode"
}